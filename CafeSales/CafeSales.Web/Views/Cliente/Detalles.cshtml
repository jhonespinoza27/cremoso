@model Cliente
@{ ViewData["Title"] = "Detalle del Cliente"; }

<div style="max-width: 700px;">
    <div class="card">
        <div class="card-header"><i class="bi bi-person me-1"></i> @Model.Nombre</div>
        <div class="card-body">
            <div class="d-flex gap-3 flex-wrap">
                <div>
                    <div class="kpi-label">DNI / RUC</div>
                    <div class="fw-bold">@(Model.Documento ?? "No registrado")</div>
                </div>
                <div>
                    <div class="kpi-label">Teléfono</div>
                    <div class="fw-bold">@(Model.Telefono ?? "No registrado")</div>
                </div>
                <div>
                    <div class="kpi-label">Estado</div>
                    <span class="badge @(Model.Activo ? "badge-success" : "badge-danger")">
                        @(Model.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>
            </div>
            <div class="mt-3">
                <div class="kpi-label">Correo</div>
                <div>@(Model.Correo ?? "No registrado")</div>
            </div>
            <div class="mt-3">
                <div class="kpi-label">Dirección</div>
                <div>@(Model.Direccion ?? "No registrada")</div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a asp-action="Editar" asp-route-id="@Model.ClienteId" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
</div>
