@model IEnumerable<Cliente>
@{
    ViewData["Title"] = "Clientes";
    ViewData["HeaderAction"] = "<a href='/Cliente/Crear' class='btn btn-primary btn-sm'><i class='bi bi-plus-lg'></i> Nuevo Cliente</a>";
}

<form method="get" class="filter-bar">
    <input type="text" name="busqueda" class="form-control" placeholder="Buscar por nombre, documento o correo..." value="@ViewBag.Busqueda" />
    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Buscar</button>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-x-lg"></i> Limpiar</a>
</form>

<div class="card">
    <div class="card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Documento</th>
                            <th>Teléfono</th>
                            <th>Correo</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@c.Nombre</td>
                                <td>@(c.Documento ?? "—")</td>
                                <td>@(c.Telefono ?? "—")</td>
                                <td>@(c.Correo ?? "—")</td>
                                <td class="text-end">
                                    <a asp-action="Detalles" asp-route-id="@c.ClienteId" class="btn btn-sm btn-secondary" title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Editar" asp-route-id="@c.ClienteId" class="btn btn-sm btn-secondary" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <form asp-action="Eliminar" asp-route-id="@c.ClienteId" method="post" style="display:inline;"
                                              onsubmit="return confirm('¿Está seguro de eliminar este cliente?');">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-people"></i>
                <h5>No se encontraron clientes</h5>
                <p>Agregue un nuevo cliente para comenzar.</p>
            </div>
        }
    </div>
</div>
