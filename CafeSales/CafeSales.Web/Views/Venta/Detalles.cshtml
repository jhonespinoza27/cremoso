@model Venta
@{ ViewData["Title"] = $"Venta #{Model.VentaId}"; }

<div style="max-width: 800px;">
    <div class="card mb-3">
        <div class="card-header"><i class="bi bi-receipt me-1"></i> Información de la Venta</div>
        <div class="card-body">
            <div class="d-flex gap-3 flex-wrap">
                <div>
                    <div class="kpi-label">N° Venta</div>
                    <div class="fw-bold">#@Model.VentaId</div>
                </div>
                <div>
                    <div class="kpi-label">Fecha</div>
                    <div class="fw-bold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div>
                    <div class="kpi-label">Cliente</div>
                    <div class="fw-bold">@Model.Cliente.Nombre</div>
                </div>
                <div>
                    <div class="kpi-label">Vendedor</div>
                    <div class="fw-bold">@(Model.Usuario.NombreCompleto ?? Model.Usuario.NombreUsuario)</div>
                </div>
                <div>
                    <div class="kpi-label">Total</div>
                    <div class="cart-total">$@Model.Total.ToString("N2")</div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Observacion))
            {
                <div class="mt-2">
                    <div class="kpi-label">Observación</div>
                    <div>@Model.Observacion</div>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="bi bi-list-ul me-1"></i> Detalle de Productos</div>
        <div class="card-body" style="padding: 0;">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="text-end">Precio Unit.</th>
                        <th class="text-end">Cantidad</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Detalles)
                    {
                        <tr>
                            <td class="fw-semibold">@d.Producto.Nombre</td>
                            <td class="text-end">$@d.PrecioUnit.ToString("N2")</td>
                            <td class="text-end">@d.Cantidad</td>
                            <td class="text-end fw-bold">$@((d.Cantidad * d.PrecioUnit).ToString("N2"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end fw-bold" style="font-size:1.1rem;">TOTAL:</td>
                        <td class="text-end cart-total">$@Model.Total.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
</div>
