@model IEnumerable<Venta>
@{
    ViewData["Title"] = "Ventas";
    ViewData["HeaderAction"] = "<a href='/Venta/Registrar' class='btn btn-primary btn-sm'><i class='bi bi-plus-lg'></i> Nueva Venta</a>";
}

<form method="get" class="filter-bar">
    <input type="date" name="fechaInicio" class="form-control" style="max-width:180px;" value="@ViewBag.FechaInicio" />
    <input type="date" name="fechaFin" class="form-control" style="max-width:180px;" value="@ViewBag.FechaFin" />
    <select name="clienteId" class="form-select" style="max-width:200px;">
        <option value="">Todos los clientes</option>
        @foreach (var item in (SelectList)ViewBag.Clientes)
        {
            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
        }
    </select>
    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Filtrar</button>
    <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-x-lg"></i> Limpiar</a>
</form>

<div class="card">
    <div class="card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th>Vendedor</th>
                            <th class="text-end">Productos</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in Model)
                        {
                            <tr>
                                <td><span class="badge badge-primary">#@v.VentaId</span></td>
                                <td>@v.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-semibold">@v.Cliente.Nombre</td>
                                <td class="text-muted">@(v.Usuario.NombreCompleto ?? v.Usuario.NombreUsuario)</td>
                                <td class="text-end">@v.Detalles.Sum(d => d.Cantidad)</td>
                                <td class="text-end fw-bold">$@v.Total.ToString("N2")</td>
                                <td class="text-end">
                                    <a asp-action="Detalles" asp-route-id="@v.VentaId" class="btn btn-sm btn-secondary" title="Ver Detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-cart"></i>
                <h5>No se encontraron ventas</h5>
                <p>Registre una nueva venta para comenzar.</p>
            </div>
        }
    </div>
</div>
