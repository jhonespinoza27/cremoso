<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CafeCremoso</title>
    <meta name="description" content="Sistema de Ventas de Cafetería - CafeCremoso"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <div class="brand-icon">☕</div>
                <div class="brand-text">
                    <h5>CafeCremoso</h5>
                    <small>Sistema de Ventas</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-title">Principal</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>

                <div class="nav-section-title">Gestión</div>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Producto" ? "active" : "")"
                   asp-controller="Producto" asp-action="Index">
                    <i class="bi bi-cup-hot-fill"></i> Productos
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cliente" ? "active" : "")"
                   asp-controller="Cliente" asp-action="Index">
                    <i class="bi bi-people-fill"></i> Clientes
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Venta" ? "active" : "")"
                   asp-controller="Venta" asp-action="Index">
                    <i class="bi bi-cart-fill"></i> Ventas
                </a>

                @if (User.IsInRole("Administrador"))
                {
                    <div class="nav-section-title">Administración</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuario" ? "active" : "")"
                       asp-controller="Usuario" asp-action="Index">
                        <i class="bi bi-shield-lock-fill"></i> Usuarios
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reporte" ? "active" : "")"
                       asp-controller="Reporte" asp-action="Index">
                        <i class="bi bi-bar-chart-fill"></i> Reportes
                    </a>
                }
            </nav>

            <div class="sidebar-user">
                <div class="user-avatar">
                    @(User.FindFirst("NombreCompleto")?.Value?.Substring(0, 1).ToUpper() ?? "U")
                </div>
                <div class="user-info">
                    <div class="user-name">@(User.FindFirst("NombreCompleto")?.Value ?? User.Identity?.Name)</div>
                    <div class="user-role">@(User.IsInRole("Administrador") ? "Administrador" : "Vendedor")</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin-left: auto;">
                    <button type="submit" class="btn" style="background: none; color: rgba(255,255,255,0.5); padding: 6px;"
                            title="Cerrar sesión">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </aside>

        <!-- Main content -->
        <main class="main-content">
            <div class="content-header">
                <h4>@ViewData["Title"]</h4>
                @if (ViewData["HeaderAction"] != null)
                {
                    @Html.Raw(ViewData["HeaderAction"])
                }
            </div>
            <div class="content-body">
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    }
    else
    {
        @RenderBody()
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
