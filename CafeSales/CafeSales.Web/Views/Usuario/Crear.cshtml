@model UsuarioViewModel
@{ ViewData["Title"] = "Nuevo Usuario"; }

<div style="max-width: 500px;">
    <div class="card">
        <div class="card-header"><i class="bi bi-person-plus me-1"></i> Crear Usuario</div>
        <div class="card-body">
            <form asp-action="Crear" method="post">
                <div class="form-group">
                    <label asp-for="NombreUsuario" class="form-label"></label>
                    <input asp-for="NombreUsuario" class="form-control" placeholder="Nombre de usuario" />
                    <span asp-validation-for="NombreUsuario" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="NombreCompleto" class="form-label"></label>
                    <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre completo" />
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Mínimo 6 caracteres" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="RolId" class="form-label"></label>
                    <select asp-for="RolId" class="form-select" asp-items="@((SelectList)ViewBag.Roles)">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="RolId" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Guardar</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
