@model Producto
@{ ViewData["Title"] = "Detalle del Producto"; }

<div style="max-width: 700px;">
    <div class="card">
        <div class="card-header"><i class="bi bi-cup-hot me-1"></i> @Model.Nombre</div>
        <div class="card-body">
            <div class="d-flex gap-3 flex-wrap">
                <div>
                    <div class="kpi-label">Categoría</div>
                    <div class="fw-bold">@Model.Categoria.Nombre</div>
                </div>
                <div>
                    <div class="kpi-label">Precio</div>
                    <div class="cart-total">$@Model.Precio.ToString("N2")</div>
                </div>
                <div>
                    <div class="kpi-label">Stock</div>
                    <div class="fw-bold">@Model.Stock</div>
                </div>
                <div>
                    <div class="kpi-label">Estado</div>
                    <span class="badge @(Model.Activo ? "badge-success" : "badge-danger")">
                        @(Model.Activo ? "Activo" : "Inactivo")
                    </span>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
            {
                <div class="mt-3">
                    <div class="kpi-label">Descripción</div>
                    <div>@Model.Descripcion</div>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Editar" asp-route-id="@Model.ProductoId" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Editar
            </a>
        }
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
    </div>
</div>
