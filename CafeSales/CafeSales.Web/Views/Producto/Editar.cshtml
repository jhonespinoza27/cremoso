@model Producto
@{ ViewData["Title"] = "Editar Producto"; }

<div style="max-width: 600px;">
    <div class="card">
        <div class="card-header"><i class="bi bi-pencil me-1"></i> Editar Producto</div>
        <div class="card-body">
            <form asp-action="Editar" method="post">
                <input type="hidden" asp-for="ProductoId" />
                <input type="hidden" asp-for="Activo" />
                <div class="form-group">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <div class="form-group" style="flex:1;">
                        <label asp-for="Precio" class="form-label"></label>
                        <input asp-for="Precio" class="form-control" type="number" step="0.01" min="0.01" />
                        <span asp-validation-for="Precio" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label asp-for="Stock" class="form-label"></label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="CategoriaId" class="form-label"></label>
                    <select asp-for="CategoriaId" class="form-select" asp-items="@((SelectList)ViewBag.Categorias)">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger"></span>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Actualizar</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
