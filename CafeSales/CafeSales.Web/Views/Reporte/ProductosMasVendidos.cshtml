@model ReporteProductosViewModel
@{ ViewData["Title"] = "Productos Más Vendidos"; }

<form method="get" class="filter-bar">
    <div>
        <label class="form-label mb-0">Desde</label>
        <input type="date" name="fechaInicio" class="form-control" value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
    </div>
    <div>
        <label class="form-label mb-0">Hasta</label>
        <input type="date" name="fechaFin" class="form-control" value="@Model.FechaFin.ToString("yyyy-MM-dd")" />
    </div>
    <div style="padding-top: 20px;">
        <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i> Consultar</button>
    </div>
</form>

<div class="card">
    <div class="card-body" style="padding: 0;">
        @if (Model.Productos.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th class="text-end">Cantidad Vendida</th>
                            <th class="text-end">Ingresos</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var p in Model.Productos)
                        {
                            <tr>
                                <td>
                                    @if (rank <= 3)
                                    {
                                        <span style="font-size: 1.2rem;">@(rank == 1 ? "🥇" : rank == 2 ? "🥈" : "🥉")</span>
                                    }
                                    else
                                    {
                                        @rank
                                    }
                                </td>
                                <td class="fw-semibold">@p.Nombre</td>
                                <td><span class="badge badge-primary">@p.Categoria</span></td>
                                <td class="text-end fw-bold">@p.CantidadVendida</td>
                                <td class="text-end fw-bold">$@p.Ingresos.ToString("N2")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h5>Sin datos en este período</h5>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver a Reportes</a>
</div>
